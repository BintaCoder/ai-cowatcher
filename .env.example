# Global mock switch — AI providers use cheap mocks; infra health checks stay real.
MOCK_MODE=true

# App
APP_NAME=ai-cowatcher
APP_ENV=development
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000

# PostgreSQL (metadata DB)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=cowatcher
POSTGRES_PASSWORD=cowatcher
POSTGRES_DB=cowatcher

# Redis (cache)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Qdrant (vector DB)
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=
QDRANT_COLLECTION=title_segments
QDRANT_KNOWLEDGE_COLLECTION=title_knowledge

# Neo4j (character intelligence graph) — leave NEO4J_URI empty to disable the
# character graph (character_lookup then returns "no info yet"). Set it to run
# the offline enrichment and enable spoiler-safe character/relationship answers.
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=cowatcher
NEO4J_DATABASE=neo4j

# MinIO (object storage)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=cowatcher
MINIO_SECURE=false

# FFmpeg (subprocess path)
FFMPEG_BIN=ffmpeg

# Speech recognition (pilot: small/medium, int8, CPU)
WHISPER_MODEL_SIZE=small
WHISPER_COMPUTE_TYPE=int8
WHISPER_DEVICE=cpu
WHISPER_NUM_WORKERS=1

# Face recognition
INSIGHTFACE_MODEL=buffalo_l
INSIGHTFACE_CTX_ID=-1

# Speaker diarization (pyannote.audio) — runs offline alongside face clustering.
# Requires a Hugging Face token with access to the gated diarization model:
# https://huggingface.co/pyannote/speaker-diarization-3.1
DIARIZATION_MODEL=pyannote/speaker-diarization-3.1
HUGGINGFACE_TOKEN=

# Character intelligence graph (offline enrichment)
# Minimum face/speaker co-occurrence count to link a voice cluster to a face.
CHARACTER_LINK_MIN_COOCCUR=1

# Embeddings
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=mps    

# Vision captioning via LiteLLM (cheap vision model, swappable)
VISION_MODEL=gemini/gemini-2.0-flash-lite
VISION_MAX_TOKENS=256
# Throttle vision API calls during ingest (avoids OpenAI TPM 429 bursts)
VISION_CAPTION_DELAY_SEC=1.0
VISION_CAPTION_MAX_RETRIES=8
VISION_FRAME_MAX_SIZE=512

# Conversation LLM via LiteLLM — tiered routing (fast default, escalated when needed)
LLM_TIER_FAST_MODEL=openai/gpt-4o-mini
LLM_TIER_ESCALATED_MODEL=openai/gpt-4o
LLM_ESCALATION_STRATEGY=heuristic
LLM_ESCALATION_MIN_CHARS=120
LLM_ESCALATION_KEYWORDS=why,how,explain,compare,motivation,relationship,theme,symbolism,foreshadow
LLM_MOCK_TIER_FAST_MODEL=mock-llm-fast
LLM_MOCK_TIER_ESCALATED_MODEL=mock-llm-escalated

# Legacy aliases (fast tier defaults match LLM_TIER_FAST_MODEL)
LLM_PRIMARY_MODEL=openai/gpt-4o-mini
LLM_FALLBACK_MODEL=anthropic/claude-3-5-haiku-latest
LLM_MOCK_MODEL=mock-llm
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.2

# Provider API keys (unused when MOCK_MODE=true)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GOOGLE_API_KEY=

# Cast / actor lookup via TMDB (public cast metadata, not a plot spoiler).
# Get a free API key at https://www.themoviedb.org/settings/api
# Cast lookup is enabled only when TMDB_API_KEY is set and MOCK_MODE=false.
TMDB_API_KEY=
# Map your internal title_id -> the real movie/show name used for TMDB search.
# Example: {"demo": "Kids", "thriller-001": "Knives Out (2019)"}
TITLE_NAMES={"demo": "Kids Find Boyfriend For Single Mom"}
TMDB_MAX_CAST=10
# Some networks/ISPs intermittently reset the TLS handshake to api.themoviedb.org.
# Retry transient connection failures before giving up. If TMDB is heavily filtered
# on your network, raise TMDB_MAX_RETRIES or route via a VPN / HTTPS_PROXY.
TMDB_MAX_RETRIES=5
TMDB_RETRY_BACKOFF_SEC=0.5

# Navigation / seek (full-title semantic search, no spoiler filter)
NAVIGATION_TOP_K=15

# Curated knowledge base (RAG for non-spoiler public facts)
KNOWLEDGE_TOP_K=5
KNOWLEDGE_DIR=knowledge

# Per-user conversation memory (Postgres + Redis session cache)
USER_MEMORY_MAX_TURNS=10
USER_MEMORY_CACHE_TURNS=20
USER_MEMORY_REDIS_TTL_SEC=3600

# Event-driven offline ingestion (Kafka / RabbitMQ / in-memory)
# memory — no broker needed (local dev / tests)
# rabbitmq — smaller deployments (default for production pilot)
# kafka — larger-scale deployments
MESSAGE_BROKER=memory
INGEST_TOPIC=title.ingest
INGEST_QUEUE_NAME=title.ingest
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CONSUMER_GROUP=cowatcher-ingest

# Prometheus metrics (GET /metrics on API; worker exposes :9100/metrics)
PROMETHEUS_ENABLED=true
WORKER_METRICS_PORT=9100
